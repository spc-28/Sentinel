# Copy to .env for local development: cp .env.example .env

# --- General ---
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
