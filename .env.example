# Copy to .env for local development: cp .env.example .env

# --- General ---
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_JSON=false

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Neo4j (service dependency graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinelpass


# --- LLM / agents ---
# ANTHROPIC_API_KEY=sk-ant-...   # required for the investigating agent
# Cheapest capable default; use anthropic/claude-sonnet-4-6 for harder reasoning.
LLM_MODEL=anthropic/claude-haiku-4-5
AGENT_MAX_STEPS=15

# --- Local fine-tuned model + routing (Part 15 experiment) ---
MODEL_ROUTING_ENABLED=false
LOCAL_LLM_MODEL=openai/qwen2.5-rca
LOCAL_LLM_BASE_URL=http://localhost:8001/v1
LOCAL_LLM_API_KEY=local

# --- Alert correlation ---
CORRELATION_WINDOW_MINUTES=5
SEMANTIC_CORRELATION_ENABLED=false  
SEMANTIC_SIMILARITY_THRESHOLD=0.6

# --- RAG ---
NLI_SUPPORT_THRESHOLD=0.5
LOG_INDEX_WINDOW_DAYS=7

# --- Memory (learning from past incidents) ---
MEMORY_DEFAULT_WEIGHT=1.0
MEMORY_SEMANTIC_THRESHOLD=0.6
MEMORY_STRONG_MATCH_THRESHOLD=0.82   # recall score above which we start from a known cause
MEMORY_MERGE_MIN_CLUSTER=2
MEMORY_MERGE_SECONDS=21600           # background pattern-merge interval (6h)

# --- MCP (Sentinel server) ---
SENTINEL_API_URL=http://localhost:8000
MCP_API_KEY=sentinel-dev-key   # change me; clients send this in X-Sentinel-Key
MCP_HOST=127.0.0.1
MCP_PORT=8765

# --- Observability (Langfuse) ---
# These match the headless-init keys in docker-compose (make langfuse).
LANGFUSE_HOST=http://localhost:3000

# --- Email reports (Gmail SMTP) ---
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# EMAIL_TO=oncall@example.com
# EMAIL_FROM=you@gmail.com          # defaults to SMTP_USER
REPORT_LINK_BASE=http://localhost:8000/investigations

# --- GitHub (optional) ---
# GITHUB_TOKEN=ghp_...              # if set (and a service has a real repo_url),
